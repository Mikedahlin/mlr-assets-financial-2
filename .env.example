# Environment variables for mlr-assets-financials
# Rename to .env and customize values for your deployment.

OAUTH_SERVER_URL=https://your-oauth-server
JWT_SECRET=very-secure-secret
DATABASE_URL=postgresql://user:pass@localhost:5432/dbname
VITE_APP_ID=your-app-id
OWNER_OPEN_ID=owner-open-id
STRIPE_SECRET_KEY=sk_test_...replace
VITE_STRIPE_PRICE_ID=price_xxx
BUILT_IN_FORGE_API_URL=https://forge.api.url
BUILT_IN_FORGE_API_KEY=forge-api-key
CORS_ORIGINS=http://localhost:3000

# Optional analytics placeholders (avoid undefined during build)
VITE_ANALYTICS_ENDPOINT=https://umami.example.com
VITE_ANALYTICS_WEBSITE_ID=your-umami-id
